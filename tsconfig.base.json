{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "strict": true,
    "skipLibCheck": true,
    "noUncheckedIndexedAccess": true,
    "baseUrl": ".",
    "paths": {
      "@branchlab/core": ["packages/core/src/index.ts"],
      "@branchlab/core/*": ["packages/core/src/*"],
      "@branchlab/policy": ["packages/policy/src/index.ts"],
      "@branchlab/policy/*": ["packages/policy/src/*"],
      "@branchlab/sdk": ["packages/sdk/src/index.ts"],
      "@branchlab/sdk/*": ["packages/sdk/src/*"]
    }
  }
}
