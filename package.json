{
  "name": "agent-twin-lab",
  "private": true,
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "dev": "turbo dev",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "e2e": "turbo e2e",
    "e2e:matrix": "pnpm --filter @branchlab/web e2e:matrix",
    "demo": "turbo demo",
    "e2e:visual": "pnpm --filter @branchlab/web e2e:visual",
    "audit:deps": "pnpm audit --prod --audit-level high",
    "sast": "bash scripts/sast_scan.sh",
    "scan:secrets": "bash scripts/scan_secrets.sh",
    "sbom": "mkdir -p artifacts && pnpm dlx @cyclonedx/cdxgen -t js -o artifacts/sbom.cdx.json",
    "licenses:report": "mkdir -p artifacts && pnpm dlx license-checker --json --out artifacts/licenses.json",
    "metadata": "tsx scripts/build_metadata.ts",
    "package:release": "bash scripts/package_release.sh",
    "smoke:prod": "tsx scripts/smoke_prod.ts",
    "preflight": "pnpm check && pnpm e2e && pnpm demo && pnpm e2e:visual && pnpm e2e:matrix && pnpm perf:budget && pnpm audit:deps && pnpm sast && pnpm scan:secrets && pnpm smoke:prod",
    "migrate:up": "pnpm --filter @branchlab/web migrate:up",
    "migrate:down": "pnpm --filter @branchlab/web migrate:down",
    "migrate:status": "pnpm --filter @branchlab/web migrate:status",
    "backup": "pnpm --filter @branchlab/web backup",
    "restore": "pnpm --filter @branchlab/web restore",
    "recover": "pnpm --filter @branchlab/web recover",
    "perf:budget": "pnpm --filter @branchlab/web perf:budget",
    "profile:harness": "pnpm --filter @branchlab/web profile:harness",
    "benchmark:suite": "pnpm --filter @branchlab/web benchmark:suite"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "eslint": "^9.35.0",
    "prettier": "^3.6.2",
    "tsx": "^4.20.5",
    "turbo": "^2.5.6",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
